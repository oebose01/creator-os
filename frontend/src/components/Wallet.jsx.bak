import React, { useState, useEffect } from 'react';
import { useAuth } from '../hooks/useAuth';

const API_BASE = import.meta.env.VITE_API_BASE || 'http://localhost:8000';

export default function Wallet() {
  const { user, loading: authLoading } = useAuth();
  const [balance, setBalance] = useState(null);
  const [amount, setAmount] = useState('');
  const [paymentMethod, setPaymentMethod] = useState('stripe');
  const [transactions, setTransactions] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');

  // Fetch balance when user is available
  useEffect(() => {
    if (!user) return;
    const fetchBalance = async () => {
      setLoading(true);
      try {
        const res = await fetch(${API_BASE}/api/balance/);
        if (!res.ok) throw new Error('Failed to fetch balance');
        const data = await res.json();
        setBalance(data.balance);
        // Mock transactions for now
        setTransactions([
          { id: 1, type: 'credit', amount: 100, description: 'Stripe deposit', date: new Date().toISOString() }
        ]);
      } catch (err) {
        setError(err.message);
      } finally {
        setLoading(false);
      }
    };
    fetchBalance();
  }, [user]);

  const handleBuy = async () => {
    if (!amount || !user) return;
    setLoading(true);
    setError('');
    try {
      if (paymentMethod === 'stripe') {
        const res = await fetch(${API_BASE}/api/create-stripe-checkout, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amount: parseFloat(amount), userId: user.id })
        });
        const { url } = await res.json();
        window.location.href = url;
      } else if (paymentMethod === 'lightning') {
        const res = await fetch(${API_BASE}/api/create-lightning-invoice, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ amount: parseFloat(amount) })
        });
        const { invoice, paymentRequest } = await res.json();
        alert(Lightning invoice created: );
        // In a real app, you'd display a QR code
      } else if (paymentMethod === 'internal') {
        // For demo, just add tokens locally (backend would handle this)
        const res = await fetch(${API_BASE}/api/transfer-tokens, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ fromUserId: 'system', toUserId: user.id, amount: parseFloat(amount) })
        });
        if (!res.ok) throw new Error('Transfer failed');
        const data = await res.json();
        setBalance(data.newBalance);
        alert('Tokens added successfully!');
      }
    } catch (err) {
      setError(err.message);
    } finally {
      setLoading(false);
    }
  };

  if (authLoading) return <div className="p-4">Loading user...</div>;
  if (!user) return <div className="p-4">Please log in to view your wallet.</div>;

  return (
    <div className="p-4 border rounded-lg shadow-sm bg-white dark:bg-gray-800">
      <h2 className="text-xl font-bold mb-4">Wallet</h2>
      {loading && <p>Loading...</p>}
      {error && <p className="text-red-500">{error}</p>}
      <div className="mb-4">
        <span className="text-lg">Balance: </span>
        <span className="text-2xl font-bold">{balance ?? '—'} HuhlyCoin</span>
      </div>

      <div className="mb-4">
        <h3 className="font-semibold mb-2">Buy Tokens</h3>
        <input
          type="number"
          value={amount}
          onChange={(e) => setAmount(e.target.value)}
          placeholder="Amount"
          className="border p-2 mr-2 rounded"
        />
        <select
          value={paymentMethod}
          onChange={(e) => setPaymentMethod(e.target.value)}
          className="border p-2 mr-2 rounded"
        >
          <option value="stripe">Credit Card (Stripe)</option>
          <option value="lightning">Lightning</option>
          <option value="internal">HuhlyCoin Credit</option>
        </select>
        <button
          onClick={handleBuy}
          disabled={loading || !amount}
          className="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 disabled:opacity-50"
        >
          Buy
        </button>
      </div>

      <div>
        <h3 className="font-semibold mb-2">Recent Transactions</h3>
        {transactions.length === 0 ? (
          <p>No transactions yet.</p>
        ) : (
          <ul className="space-y-1">
            {transactions.map(tx => (
              <li key={tx.id} className="text-sm">
                {tx.date.slice(0,10)} – {tx.description}: {tx.amount} HuhlyCoin
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  );
}
